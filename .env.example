# Internal Docker networking is hardcoded in docker-compose.yml — no configuration needed.

# --- LLM Provider Configuration ---
# Set LLM_PROVIDER to one of: openai | anthropic | google | openrouter
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# API keys — only the key matching your chosen provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# --- Notification Configuration ---
# Slack webhook URL
#SLACK_WEBHOOK_URL=slack://hooks.slack.com/services/your/webhook/url

# Email SMTP URL
# For Gmail, Apprise needs an explicit mailto format with STARTTLS.
# The code will convert this SMTP URL into the correct Apprise mailto format.
EMAIL_SMTP_URL=smtp://username:password@smtp.gmail.com:587

# Discord webhook URL
#DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
