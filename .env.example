# ============================================================
# SRE Incident Triage Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the required values.
# Internal Docker networking is hardcoded in docker-compose.yml
# — no configuration needed for DATABASE_URL, APPRISE_URL, etc.
# ============================================================

# --- LLM Provider (REQUIRED) --------------------------------
# Set LLM_PROVIDER to one of: openai | anthropic | google | openrouter | aigateway
LLM_PROVIDER=openrouter

# Optional: override the default model for your chosen provider.
# If unset, the default model for the provider is used.
# Defaults: openrouter → google/gemini-3.1-flash-lite-preview
#           openai → gpt-5.4-nano
#           anthropic → claude-haiku-4-5-20251001
#           google → gemini-3.1-flash-lite-preview
#           aigateway → google/gemini-3.1-flash-lite-preview
#LLM_MODEL=

# --- API Keys (only the one matching your provider is required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=

# --- Notification Configuration (optional) -------------------
# All notifications are optional. If URLs are empty, the hook
# logs a warning and skips that channel.

# Discord webhook URL (get it from Discord → Server Settings → Integrations → Webhooks)
#DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Email SMTP URL (Apprise mailto format). For Gmail with STARTTLS:
#EMAIL_SMTP_URL=smtp://username:password@smtp.gmail.com:587

# --- Notification Toggles ------------------------------------
NOTIFY_EMAIL_ON_TRIAGE=true
NOTIFY_DISCORD_ON_TRIAGE=true

# Comma-separated list of extra email addresses to CC on triage notifications
#NOTIFY_CC_EMAILS=

# --- Peppermint Ticketing (defaults work with docker-compose) -
# No changes needed — the defaults match the Peppermint container
# configured in docker-compose.yml (admin@admin.com / 1234).
#PEPPERMINT_URL=http://peppermint:5003/api/v1
#PEPPERMINT_EMAIL=admin@admin.com
#PEPPERMINT_PASSWORD=1234
