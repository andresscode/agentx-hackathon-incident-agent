# Internal Docker networking is hardcoded in docker-compose.yml — no configuration needed.

# --- LLM Provider Configuration ---
# Set LLM_PROVIDER to one of: openai | anthropic | google | openrouter
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# API keys — only the key matching your chosen provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
