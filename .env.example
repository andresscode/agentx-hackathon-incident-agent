# Internal Docker networking is hardcoded in docker-compose.yml — no configuration needed.

# --- LLM Provider Configuration ---
# Set LLM_PROVIDER to one of: openai | anthropic | google | openrouter | aigateway
LLM_PROVIDER=openrouter

# Fast model for prompt injection and initial image analysis (Agent Step 1)
# Optional — if unset, uses provider default fast model
LLM_MODEL=

# Professional model for complex tasks (classification, code search, summarization - Agent Steps 2-3)
# Optional — if unset, uses provider default professional model
LLM_PRO_MODEL=

# API keys — only the key matching your chosen provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=
