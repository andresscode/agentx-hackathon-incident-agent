DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/incident_agent

# --- LLM Provider Configuration ---
# Set LLM_PROVIDER to one of: openai | anthropic | google | openrouter
LLM_PROVIDER=openrouter


# API keys — only the key matching your chosen provider is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
